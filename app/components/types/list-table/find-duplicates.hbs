{{! Modal }}
<div
  class="modal fade"
  id="findDuplicatesModal"
  tabindex="-1"
  aria-labelledby="findDuplicatesModalLabel"
  aria-hidden="true"
  {{on "hidden.bs.modal" this.reset}}
>
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">

      <div class="modal-header">
        <h1 class="modal-title fst-italic fs-5" id="findDuplicatesModalLabel">
          Find Duplicates —
          <span class="text-capitalize">{{this.type.currentType.plural}}</span>
        </h1>
        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal"
          aria-label="Close"
        ></button>
      </div>

      <div class="modal-body">

        {{! Step 1: Field picker }}
        <p class="text-muted mb-3">
          Select the fields to compare. Two records are considered duplicates
          when every selected field matches exactly.
        </p>

        <div class="d-flex align-items-center gap-2 mb-3">
          <button
            type="button"
            class="btn btn-outline-{{this.colormodes.inverseMode}} btn-sm"
            {{on "click" this.selectAllFields}}
          >Select all</button>
          <button
            type="button"
            class="btn btn-outline-{{this.colormodes.inverseMode}} btn-sm"
            {{on "click" this.clearAllFields}}
          >Clear</button>
        </div>

        {{! Field checkboxes }}
        <div class="row g-2 mb-4">
          {{#each this.comparableModules as |module|}}
            <div class="col-6 col-md-4 col-lg-3">
              <div
                class="form-check border p-2
                  {{if
                    (this.isFieldSelected module.input_slug)
                    'border-primary bg-primary bg-opacity-10'
                  }}"
              >
                <Input
                  class="form-check-input mx-1"
                  @type="checkbox"
                  @checked={{this.isFieldSelected module.input_slug}}
                  id="dup-field-{{module.input_slug}}"
                  {{on "change" (fn this.toggleField module.input_slug)}}
                />
                <label
                  class="form-check-label text-truncate d-block cursor-pointer"
                  for="dup-field-{{module.input_slug}}"
                >
                  {{module.input_slug}}
                  {{#if module.input_primary}}
                    <i
                      class="fa-solid fa-star fa-xs text-warning ms-1"
                      title="Primary field"
                    ></i>
                  {{/if}}
                </label>
                <small class="text-muted mx-1">{{module.input_type}}</small>
              </div>
            </div>
          {{else}}
            <div class="col-12">
              <p class="text-muted fst-italic">No comparable fields found for
                this track.</p>
            </div>
          {{/each}}
        </div>

        {{! Results area }}
        {{#if this.scanning}}
          <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
              <span class="visually-hidden">Scanning…</span>
            </div>
            <p class="mt-3 text-muted">Scanning all records…</p>
          </div>

        {{else if this.noDuplicatesFound}}
          <div
            class="alert alert-success d-flex align-items-center gap-2"
            role="alert"
          >
            <i class="fa-solid fa-circle-check fa-lg"></i>
            <span>No duplicates found across
              <strong>{{this.selectedFields.length}}</strong>
              {{if (eq this.selectedFields.length 1) "field" "fields"}}.
            </span>
          </div>

        {{else if this.hasScanned}}
          <div
            class="alert alert-warning d-flex align-items-center gap-2 mb-3"
            role="alert"
          >
            <i class="fa-solid fa-triangle-exclamation fa-lg"></i>
            <span>
              Found
              <strong>{{this.duplicateGroups.length}}</strong>
              duplicate
              {{if (eq this.duplicateGroups.length 1) "group" "groups"}}
              ({{this.totalDuplicateObjects}}
              objects total). Use the eye icon to inspect a record, then the
              trash icon to delete it one at a time.
            </span>
          </div>

          {{#each this.paginatedGroups as |group groupIndex|}}
            <div class="mb-3 border border-warning">
              <div
                class="px-3 py-2 bg-warning bg-opacity-10 d-flex justify-content-between align-items-center"
              >
                <span class="fw-semibold">
                  Group
                  {{add (add groupIndex this.paginatedGroupOffset) 1}}
                  <span class="badge bg-warning text-dark ms-1">{{group.length}}
                    records</span>
                </span>
              </div>

              <div class="overflow-hidden">
                <table class="table table-sm table-hover mb-0 types-data-table w-100" style="table-layout: fixed;">
                  <colgroup>
                    <col style="width: 20%;">
                    {{#each this.selectedFields as |_field|}}
                      <col style="width: {{div 60 this.selectedFields.length}}%;">
                    {{/each}}
                    <col style="width: 20%;">
                  </colgroup>
                  <thead>
                    <tr>
                      <th class="ps-3">ID</th>
                      {{#each this.selectedFields as |field|}}
                        <th class="text-truncate">{{field}}</th>
                      {{/each}}
                      <th></th>
                    </tr>
                  </thead>
                  <tbody>
                    {{#each group as |snap|}}
                      <tr>
                        <td class="ps-3" style="min-width: 0;">
                          <span
                            class="slug-ellipsis text-muted d-block text-truncate"
                          >{{snap.id}}</span>
                        </td>
                        {{#each this.selectedFields as |field|}}
                          <td style="min-width: 0;">
                            <span class="d-block text-truncate">
                              {{#if (get snap.modules field)}}
                                {{get snap.modules field}}
                              {{else}}
                                <span class="text-muted fst-italic">—</span>
                              {{/if}}
                            </span>
                          </td>
                        {{/each}}
                        <td class="text-end pe-2" style="white-space: nowrap; width: 1%;">
                          <button
                            type="button"
                            class="btn btn-outline-{{this.colormodes.inverseMode}} btn-sm me-1"
                            title="{{if (eq this.expandedRecordId snap.id) 'Collapse details' 'View details'}}"
                            {{on "click" (fn this.toggleDetails snap.id)}}
                          >
                            <i class="fa-solid {{if (eq this.expandedRecordId snap.id) 'fa-eye-slash' 'fa-eye'}}"></i>
                          </button>
                          <button
                            type="button"
                            class="btn btn-outline-danger btn-sm"
                            title="Delete record"
                            {{on "click" (fn this.deleteRecord snap)}}
                          ><i class="fa-solid fa-trash"></i></button>
                        </td>
                      </tr>
                      {{#if (eq this.expandedRecordId snap.id)}}
                        <tr>
                          <td colspan={{this.detailColspan}} class="p-0" style="max-width: 0;">
                            <div class="p-3 bg-{{this.colormodes.mode}} border-top overflow-hidden">
                              <p class="text-muted small mb-2 fw-semibold">
                                modules.*
                                <span class="text-muted fw-normal ms-2">ID: {{snap.id}}</span>
                              </p>
                              <div style="overflow-x: auto; max-width: 100%;">
                                <Types::Blueprint::JsonDisplay
                                  @jsondata={{snap.modules}}
                                />
                              </div>
                            </div>
                          </td>
                        </tr>
                      {{/if}}
                    {{/each}}
                  </tbody>
                </table>
              </div>
            </div>
          {{/each}}

          {{! Pagination controls }}
          {{#if (gt this.totalPages 1)}}
            <div class="d-flex align-items-center justify-content-between mt-2 mb-1">
              <button
                type="button"
                class="btn btn-outline-{{this.colormodes.inverseMode}} btn-sm"
                disabled={{not this.hasPrevPage}}
                {{on "click" this.prevPage}}
              >
                <i class="fa-solid fa-chevron-left me-1"></i>Previous
              </button>
              <span class="text-muted small">
                Page {{add this.currentPage 1}} of {{this.totalPages}}
                <span class="ms-2 text-muted">({{this.duplicateGroups.length}} groups total)</span>
              </span>
              <button
                type="button"
                class="btn btn-outline-{{this.colormodes.inverseMode}} btn-sm"
                disabled={{not this.hasNextPage}}
                {{on "click" this.nextPage}}
              >
                Next<i class="fa-solid fa-chevron-right ms-1"></i>
              </button>
            </div>
          {{/if}}
        {{/if}}

      </div>{{! /modal-body }}

      <div
        class="modal-footer d-flex align-items-center justify-content-between p-0"
      >
        <div class="d-flex align-items-center justify-content-start">
          <button
            type="button"
            class="btn btn-outline-secondary btn-sm me-2"
            data-bs-dismiss="modal"
          >Close</button>
        </div>

        <div class="d-flex align-items-center justify-content-end">
          <button
            type="button"
            class="btn btn-primary ms-2
              {{if (eq this.selectedFields.length 0) 'disabled'}}"
            {{on "click" this.runScan}}
            disabled={{eq this.selectedFields.length 0}}
          >
            {{#if this.scanning}}
              <span
                class="spinner-border spinner-border-sm me-1"
                role="status"
              ></span>
              Scanning…
            {{else}}
              <i class="fa-solid fa-magnifying-glass me-1"></i>
              Find Duplicates
            {{/if}}
          </button>
        </div>
      </div>

    </div>
  </div>
</div>
